{
  "name": "coc",
  "version": "1.0.0",
  "private": true,
  "description": "",
  "main": "index.js",
  "scripts": {
    "build": "pnpm -r --filter \"./packages/**\" build && pnpm -r --filter \"./apps/**\" build",
    "clean": "pnpm -r --filter \"./packages/**\" clean && pnpm -r --filter \"./apps/**\" clean",
    "dev": "pnpm -r --filter \"./packages/**\" build && pnpm --filter backend start:dev",
    "dev:front": "pnpm -r --filter \"./packages/**\" build && pnpm --filter frontend dev",
    "smoke:socket": "node scripts/smoke-socket.js",
    "test:engine": "pnpm --filter @coc/engine test",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.32.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "typescript": "~5.9.3"
  },
  "dependencies": {
    "socket.io-client": "^4.8.3"
  }
}
